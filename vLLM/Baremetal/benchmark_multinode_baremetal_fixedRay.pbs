#!/bin/bash
#PBS -N baremetal_R3_2x1
#PBS -P hpc_admin
#PBS -q gpu_as
#PBS -l walltime=01:00:00
#PBS -j oe
#PBS -l place=scatter

# ============================================================
# Multi-node GPU toggle section
#
# Enable exactly ONE select line.
#
# ---- 2 nodes x 1 GPU each = 2 total GPUs ----
#PBS -l select=2:ncpus=12:ngpus=1:mpiprocs=1
export GPUS_PER_NODE=1
export TP_SIZE=1
export PP_SIZE=2
#
# ---- 2 nodes x 2 GPUs each = 4 total GPUs ----
##PBS -l select=2:ncpus=24:ngpus=2:mpiprocs=1
# export GPUS_PER_NODE=2
# export TP_SIZE=2
# export PP_SIZE=2
#
# vLLM multi-node layout:
#   TP_SIZE = GPUs per node
#   PP_SIZE = number of nodes
#
# Examples:
#   2x1 -> TP_SIZE=1, PP_SIZE=2
#   2x2 -> TP_SIZE=2, PP_SIZE=2
#
# Keep mpiprocs=1.
# Ray starts one worker process per node.
# vLLM/Ray manages the GPUs internally.
# ============================================================

set -euo pipefail

cd "${PBS_O_WORKDIR:-$HOME}" || exit 1

echo "============================================================"
echo "PBS job started"
echo "Job ID:        ${PBS_JOBID:-unknown}"
echo "Job name:      ${PBS_JOBNAME:-unknown}"
echo "Submit dir:    ${PBS_O_WORKDIR:-unknown}"
echo "Running host:  $(hostname)"
echo "Date:          $(date)"
echo "GPUS_PER_NODE: ${GPUS_PER_NODE}"
echo "TP_SIZE:       ${TP_SIZE}"
echo "PP_SIZE:       ${PP_SIZE}"
echo "============================================================"

# ------------------------------------------------------------
# Load software stack
#
# vllm/0.19.0 provides the bare-metal vLLM executable.
# nvhpc/26.3 provides the known-good HPC-X OpenMPI used with pbs_tmrsh.
# ------------------------------------------------------------
module purge
module load vllm/0.19.0
module load nvhpc/26.3

module list

# ------------------------------------------------------------
# Use HPC-X OpenMPI from NVHPC
# Same style as your working PyTorch DDP benchmark.
# ------------------------------------------------------------
NVROOT=$(dirname "$(dirname "$(dirname "$(command -v nvfortran)")")")

export PATH="${NVROOT}/comm_libs/hpcx/bin:${PATH}"
export LD_LIBRARY_PATH="${NVROOT}/comm_libs/hpcx/lib:${LD_LIBRARY_PATH:-}"

# ------------------------------------------------------------
# Project working directory on shared storage
# ------------------------------------------------------------
export BENCH_ROOT="/projects_vol/gp_hpcadmin/pham0094/guidellm_vLLMBench"

# ------------------------------------------------------------
# CUDA_VISIBLE_DEVICES fix for bare-metal vLLM
#
# This MUST happen before running any vLLM command, even `vllm --version`,
# because this bare-metal vLLM stack can crash if CUDA_VISIBLE_DEVICES
# contains GPU UUIDs.
# ------------------------------------------------------------
if [[ "$GPUS_PER_NODE" -eq 1 ]]; then
  export CUDA_VISIBLE_DEVICES=0
elif [[ "$GPUS_PER_NODE" -eq 2 ]]; then
  export CUDA_VISIBLE_DEVICES=0,1
elif [[ "$GPUS_PER_NODE" -eq 4 ]]; then
  export CUDA_VISIBLE_DEVICES=0,1,2,3
elif [[ "$GPUS_PER_NODE" -eq 8 ]]; then
  export CUDA_VISIBLE_DEVICES=0,1,2,3,4,5,6,7
else
  echo "ERROR: Unsupported GPUS_PER_NODE=$GPUS_PER_NODE"
  exit 1
fi

# ------------------------------------------------------------
# Python / Ray setup
#
# Important:
# - vllm/0.19.0 provides the bare-metal vLLM executable and module Python.
# - Ray is installed in a clean venv built with Python 3.12.13:
#     /home/pham0094/guidellm_vLLMBench/baremetal_ray
#
# We use:
#   PYTHON_BIN      = module Python used by vLLM
#   RAY_PYTHON_BIN  = venv Python used to run Ray CLI
#
# Then we add the Ray venv site-packages to PYTHONPATH so the vLLM
# module Python can import Ray when vLLM uses --distributed-executor-backend ray.
# ------------------------------------------------------------
unset PYTHONNOUSERSITE || true

export BAREMETAL_RAY_ENV="/home/pham0094/guidellm_vLLMBench/baremetal_ray"
export RAY_PYTHON_BIN="$BAREMETAL_RAY_ENV/bin/python"
export RAY_SITE_PACKAGES="$BAREMETAL_RAY_ENV/lib/python3.12/site-packages"

if [[ ! -x "$RAY_PYTHON_BIN" ]]; then
  echo "ERROR: Ray venv Python not found or not executable:"
  echo "$RAY_PYTHON_BIN"
  exit 1
fi

if [[ ! -d "$RAY_SITE_PACKAGES" ]]; then
  echo "ERROR: Ray venv site-packages directory not found:"
  echo "$RAY_SITE_PACKAGES"
  exit 1
fi

# Make Ray importable to the module-provided vLLM Python.
export PYTHONPATH="$RAY_SITE_PACKAGES:${PYTHONPATH:-}"

export PYTHON_BIN="$(command -v python3 || true)"
export VLLM_BIN="$(command -v vllm || true)"

if [[ -z "$PYTHON_BIN" ]]; then
  echo "ERROR: python3 not found after loading vllm/0.19.0"
  exit 1
fi

if [[ -z "$VLLM_BIN" ]]; then
  echo "ERROR: vllm executable not found after loading vllm/0.19.0"
  exit 1
fi

echo "============================================================"
echo "Executable check"
echo "============================================================"
echo "PYTHON_BIN:          $PYTHON_BIN"
echo "VLLM_BIN:            $VLLM_BIN"
echo "BAREMETAL_RAY_ENV:   $BAREMETAL_RAY_ENV"
echo "RAY_PYTHON_BIN:      $RAY_PYTHON_BIN"
echo "RAY_SITE_PACKAGES:   $RAY_SITE_PACKAGES"
echo "CUDA_VISIBLE_DEVICES:$CUDA_VISIBLE_DEVICES"
echo "PYTHONPATH:          ${PYTHONPATH:-unset}"
echo "python version:"
"$PYTHON_BIN" --version
echo "Ray venv python version:"
"$RAY_PYTHON_BIN" --version
echo "vLLM version:"
"$VLLM_BIN" --version || true
echo "Checking Ray from Ray venv:"
"$RAY_PYTHON_BIN" -c "import ray; print(ray.__version__)"
echo "Checking whether module Python can import Ray via PYTHONPATH:"
"$PYTHON_BIN" -c "import ray; print(ray.__version__)"

# Ray CLI through the module Python.
#
# Important:
# Ray was installed in the bare-metal Ray venv, but the vLLM Ray
# actors must also be able to import the module-provided vllm package.
# Since PYTHONPATH already exposes the Ray venv site-packages to the
# module Python, use module Python to start Ray. This keeps Ray workers
# in the same Python/module environment as vLLM.
export RAY_CMD="$PYTHON_BIN -m ray.scripts.scripts"

echo "Ray command:"
echo "$RAY_CMD"
echo "Ray version:"
$RAY_CMD --version || true
echo "============================================================"

# ------------------------------------------------------------
# Hugging Face cache
# ------------------------------------------------------------
export HF_HOME="$BENCH_ROOT/hf_home"

# ------------------------------------------------------------
# Runtime/JIT/cache directories
# ------------------------------------------------------------
export XDG_CACHE_HOME="$BENCH_ROOT/xdg_cache"
export VLLM_CACHE_ROOT="$BENCH_ROOT/vllm_cache"
export FLASHINFER_WORKSPACE_DIR="$BENCH_ROOT/flashinfer_cache"
export TORCHINDUCTOR_CACHE_DIR="$BENCH_ROOT/torchinductor_cache"
export TRITON_CACHE_DIR="$BENCH_ROOT/triton_cache"
export TMPDIR="$BENCH_ROOT/tmp"

# ------------------------------------------------------------
# CPU threading
# ------------------------------------------------------------
export OMP_NUM_THREADS=1

# ------------------------------------------------------------
# NCCL / communication settings
#
# Same known-good communication style from your PyTorch DDP test.
# Do NOT force Ethernet.
# ------------------------------------------------------------
export NCCL_IB_DISABLE=0
export TORCH_NCCL_ASYNC_ERROR_HANDLING=1

export NCCL_DEBUG=INFO
export NCCL_DEBUG_SUBSYS=INIT,NET,GRAPH

# Avoid mlx5_bond_0 failure path by explicitly selecting HCAs.
export NCCL_IB_HCA=mlx5_0,mlx5_1,mlx5_2,mlx5_3,mlx5_4,mlx5_5,mlx5_8,mlx5_9

# ------------------------------------------------------------
# Logs and outputs
# ------------------------------------------------------------
export VLLM_LOG_DIR="$BENCH_ROOT/logs"

export RUN_TAG="baremetal_qwen2p5_7b_multinode_tp${TP_SIZE}_pp${PP_SIZE}_${PBS_JOBID:-manual}_$(date +%Y%m%d_%H%M%S)"
export RUN_DIR="$BENCH_ROOT/results/$RUN_TAG"

export RAY_LOG_DIR="$RUN_DIR/ray_logs"
export VLLM_LOG_FILE="$VLLM_LOG_DIR/vllm_qwen2p5_7b_baremetal_multinode_tp${TP_SIZE}_pp${PP_SIZE}_${PBS_JOBID:-manual}.log"
export MODELS_JSON="$RUN_DIR/models.json"
export REQUEST_JSON="$RUN_DIR/request.json"
export RESPONSE_JSON="$RUN_DIR/response.json"
export RESPONSE_TXT="$RUN_DIR/response_text.txt"

mkdir -p \
  "$HF_HOME" \
  "$XDG_CACHE_HOME" \
  "$VLLM_CACHE_ROOT" \
  "$FLASHINFER_WORKSPACE_DIR" \
  "$TORCHINDUCTOR_CACHE_DIR" \
  "$TRITON_CACHE_DIR" \
  "$TMPDIR" \
  "$VLLM_LOG_DIR" \
  "$RUN_DIR" \
  "$RAY_LOG_DIR" \
  "$BENCH_ROOT/.cache/flashinfer"

if [[ -z "${PBS_NODEFILE:-}" ]] || [[ ! -f "$PBS_NODEFILE" ]]; then
  echo "ERROR: PBS_NODEFILE is not set or does not exist."
  exit 1
fi

# ------------------------------------------------------------
# Automatically derive allocation
# ------------------------------------------------------------
mapfile -t NODES < <(sort -u "$PBS_NODEFILE")

NNODES="${#NODES[@]}"
HEAD_NODE="${NODES[0]}"
NPROCS=$(wc -l < "$PBS_NODEFILE")

if [[ "$NNODES" -ne "$PP_SIZE" ]]; then
  echo "ERROR: Allocated node count NNODES=$NNODES but PP_SIZE=$PP_SIZE."
  echo "Allocated nodes:"
  printf '  %s\n' "${NODES[@]}"
  exit 1
fi

echo "============================================================"
echo "PBS allocation"
echo "============================================================"
echo "NPROCS from PBS_NODEFILE: $NPROCS"
echo "NNODES:                  $NNODES"
echo "GPUS_PER_NODE:           $GPUS_PER_NODE"
echo "NODES:"
printf '  %s\n' "${NODES[@]}"
echo "HEAD_NODE:               $HEAD_NODE"
echo "============================================================"

# ------------------------------------------------------------
# Resolve IPv4 head node IP
#
# Important:
# Do NOT use bare getent hosts here, because it may return IPv6
# link-local fe80:: addresses. Ray wants a clean IPv4 bootstrap
# address like 192.168.x.x:PORT.
# ------------------------------------------------------------
HEAD_IP="$(getent ahostsv4 "$HEAD_NODE" | awk '{print $1; exit}')"

if [[ -z "$HEAD_IP" ]]; then
  HEAD_IP="$(hostname -I 2>/dev/null | tr ' ' '\n' | awk '/^[0-9]+\./ {print; exit}')"
fi

if [[ -z "$HEAD_IP" ]]; then
  echo "ERROR: Could not resolve IPv4 address for head node: $HEAD_NODE"
  exit 1
fi

export HEAD_IP

# ------------------------------------------------------------
# Derive per-job Ray port from PBS_JOBID
# ------------------------------------------------------------
JOB_NUM=$(echo "${PBS_JOBID:-0}" | sed 's/[^0-9].*//')
if [[ -z "$JOB_NUM" ]]; then
  JOB_NUM=0
fi

export RAY_PORT=$((20000 + JOB_NUM % 40000))
export RAY_ADDRESS="${HEAD_IP}:${RAY_PORT}"

# Short local Ray temp path to avoid AF_UNIX socket path limit.
export RAY_TMP_BASE="/tmp/ray_${JOB_NUM}_${USER:-user}"

# vLLM OpenAI-compatible API server
export PORT=8000
export SERVER_URL="http://${HEAD_IP}:${PORT}"

echo "============================================================"
echo "Multi-node NON-CONTAINERIZED vLLM configuration"
echo "============================================================"
echo "JOBID:                ${PBS_JOBID:-unknown}"
echo "WORKDIR:              ${PBS_O_WORKDIR:-unknown}"
echo "DATE:                 $(date)"
echo "LAYOUT:               ${NNODES} nodes x ${GPUS_PER_NODE} GPUs"
echo "TP_SIZE:              ${TP_SIZE}"
echo "PP_SIZE:              ${PP_SIZE}"
echo "TOTAL MODEL GPUS:     $(( TP_SIZE * PP_SIZE ))"
echo "HEAD_NODE:            ${HEAD_NODE}"
echo "HEAD_IP:              ${HEAD_IP}"
echo "RAY_ADDRESS:          ${RAY_ADDRESS}"
echo "RAY_TMP_BASE:         ${RAY_TMP_BASE}"
echo "SERVER_URL:           ${SERVER_URL}"
echo "BENCH_ROOT:           ${BENCH_ROOT}"
echo "RUN_DIR:              ${RUN_DIR}"
echo "VLLM_LOG_FILE:        ${VLLM_LOG_FILE}"
echo "VLLM_BIN:             ${VLLM_BIN}"
echo "PYTHON_BIN:           ${PYTHON_BIN}"
echo "BAREMETAL_RAY_ENV:    ${BAREMETAL_RAY_ENV}"
echo "RAY_PYTHON_BIN:       ${RAY_PYTHON_BIN}"
echo "RAY_SITE_PACKAGES:    ${RAY_SITE_PACKAGES}"
echo "RAY_CMD:              ${RAY_CMD}"
echo "PYTHONPATH:           ${PYTHONPATH:-unset}"
echo "PYTHONNOUSERSITE:     ${PYTHONNOUSERSITE:-unset}"
echo "CUDA_VISIBLE_DEVICES: ${CUDA_VISIBLE_DEVICES}"
echo "NCCL_IB_DISABLE:      ${NCCL_IB_DISABLE}"
echo "NCCL_IB_HCA:          ${NCCL_IB_HCA}"
echo "NCCL_DEBUG_SUBSYS:    ${NCCL_DEBUG_SUBSYS}"
echo "NODES:                $(printf '%s ' "${NODES[@]}")"
echo "============================================================"

# ------------------------------------------------------------
# Helper: run command on one PBS allocated node using pbs_tmrsh.
#
# This matches your working PyTorch DDP communication style.
# ------------------------------------------------------------
run_on_node() {
  local node="$1"
  shift
  local cmd="$*"

  mpirun -np 1 \
    -host "$node" \
    --mca plm_rsh_agent pbs_tmrsh \
    --bind-to none \
    -x PATH \
    -x LD_LIBRARY_PATH \
    -x MANPATH \
    -x MODULEPATH \
    -x LOADEDMODULES \
    -x _LMFILES_ \
    -x BENCH_ROOT \
    -x HF_HOME \
    -x XDG_CACHE_HOME \
    -x VLLM_CACHE_ROOT \
    -x FLASHINFER_WORKSPACE_DIR \
    -x TORCHINDUCTOR_CACHE_DIR \
    -x TRITON_CACHE_DIR \
    -x TMPDIR \
    -x VLLM_LOG_DIR \
    -x RUN_DIR \
    -x RAY_LOG_DIR \
    -x VLLM_LOG_FILE \
    -x VLLM_BIN \
    -x PYTHON_BIN \
    -x BAREMETAL_RAY_ENV \
    -x RAY_PYTHON_BIN \
    -x RAY_SITE_PACKAGES \
    -x PYTHONPATH \
    -x RAY_CMD \
    -x HEAD_IP \
    -x RAY_PORT \
    -x RAY_ADDRESS \
    -x RAY_TMP_BASE \
    -x PORT \
    -x SERVER_URL \
    -x CUDA_VISIBLE_DEVICES \
    -x NCCL_IB_DISABLE \
    -x NCCL_DEBUG \
    -x NCCL_DEBUG_SUBSYS \
    -x NCCL_IB_HCA \
    -x TORCH_NCCL_ASYNC_ERROR_HANDLING \
    -x OMP_NUM_THREADS \
    bash -lc "$cmd"
}

# ------------------------------------------------------------
# Cleanup
# ------------------------------------------------------------
VLLM_PID=""

cleanup() {
  echo "============================================================"
  echo "Cleaning up vLLM and Ray"
  echo "Date: $(date)"
  echo "============================================================"

  if [[ -n "${VLLM_PID:-}" ]] && kill -0 "$VLLM_PID" 2>/dev/null; then
    echo "Stopping vLLM API server..."
    kill -TERM "-$VLLM_PID" 2>/dev/null || kill -TERM "$VLLM_PID" 2>/dev/null || true
    sleep 5

    if kill -0 "$VLLM_PID" 2>/dev/null; then
      echo "vLLM still running; sending KILL..."
      kill -KILL "-$VLLM_PID" 2>/dev/null || kill -KILL "$VLLM_PID" 2>/dev/null || true
    fi
  fi

  for node in "${NODES[@]}"; do
    echo "Stopping Ray on $node ..."
    run_on_node "$node" "$RAY_CMD stop --force" \
      > "$RAY_LOG_DIR/ray_stop_${node}.log" 2>&1 || true
  done

  echo "Cleanup complete."
}

trap cleanup EXIT

# ------------------------------------------------------------
# Pre-clean stale Ray
# ------------------------------------------------------------
echo "============================================================"
echo "Stopping any stale Ray processes"
echo "============================================================"

for node in "${NODES[@]}"; do
  echo "Pre-clean Ray on $node ..."
  run_on_node "$node" "$RAY_CMD stop --force" \
    > "$RAY_LOG_DIR/ray_prestop_${node}.log" 2>&1 || true
done

sleep 3

# ------------------------------------------------------------
# Check GPU visibility and Ray import on each allocated node
# ------------------------------------------------------------
echo "============================================================"
echo "Checking GPU visibility and Ray import on each allocated node"
echo "============================================================"

for node in "${NODES[@]}"; do
  echo "---------------- $node ----------------"
  run_on_node "$node" "
    hostname
    echo CUDA_VISIBLE_DEVICES=\${CUDA_VISIBLE_DEVICES:-unset}
    echo PYTHONPATH=\${PYTHONPATH:-unset}
    echo PYTHONNOUSERSITE=\${PYTHONNOUSERSITE:-unset}
    nvidia-smi -L
    '$PYTHON_BIN' -c 'import ray; print(ray.__version__)'
    '$PYTHON_BIN' -c 'import vllm; print("vllm import OK")'
  " || true
done

# ------------------------------------------------------------
# Start Ray head
# ------------------------------------------------------------
echo "============================================================"
echo "Starting Ray head on $HEAD_NODE"
echo "HEAD_IP:     $HEAD_IP"
echo "RAY_PORT:    $RAY_PORT"
echo "RAY_ADDRESS: $RAY_ADDRESS"
echo "============================================================"

run_on_node "$HEAD_NODE" "
  export VLLM_HOST_IP='$HEAD_IP'

  rm -rf '$RAY_TMP_BASE/head'
  mkdir -p '$RAY_TMP_BASE/head'

  setsid -f $RAY_CMD start \
    --head \
    --node-ip-address='$HEAD_IP' \
    --port='$RAY_PORT' \
    --num-gpus='$GPUS_PER_NODE' \
    --temp-dir='$RAY_TMP_BASE/head' \
    --disable-usage-stats \
    --block \
    > '$RAY_LOG_DIR/ray_head_${HEAD_NODE}.log' 2>&1 < /dev/null
"

sleep 10

# ------------------------------------------------------------
# Start Ray workers
# ------------------------------------------------------------
echo "============================================================"
echo "Starting Ray workers"
echo "============================================================"

for node in "${NODES[@]}"; do
  if [[ "$node" == "$HEAD_NODE" ]]; then
    continue
  fi

  NODE_IP="$(getent ahostsv4 "$node" | awk '{print $1; exit}')"

  if [[ -z "$NODE_IP" ]]; then
    echo "ERROR: Could not resolve IPv4 address for worker node: $node"
    exit 1
  fi

  echo "Starting Ray worker on $node, IP=$NODE_IP"

  run_on_node "$node" "
    export VLLM_HOST_IP='$NODE_IP'

    rm -rf '$RAY_TMP_BASE/$node'
    mkdir -p '$RAY_TMP_BASE/$node'

    setsid -f $RAY_CMD start \
      --address='$RAY_ADDRESS' \
      --node-ip-address='$NODE_IP' \
      --num-gpus='$GPUS_PER_NODE' \
      --temp-dir='$RAY_TMP_BASE/$node' \
      --disable-usage-stats \
      --block \
      > '$RAY_LOG_DIR/ray_worker_${node}.log' 2>&1 < /dev/null
  "
done

sleep 20

# ------------------------------------------------------------
# Check Ray cluster status from head
# ------------------------------------------------------------
echo "============================================================"
echo "Checking Ray cluster status with retries"
echo "============================================================"

# Ray/GCS can take a short time to stabilize after the head and
# workers are launched. Do not fail the whole job on one early
# transient `ray status` timeout.
RAY_READY=0
RAY_STATUS_MAX_ATTEMPTS=24
RAY_STATUS_SLEEP_SEC=5

for attempt in $(seq 1 "$RAY_STATUS_MAX_ATTEMPTS"); do
  echo "Ray status attempt ${attempt}/${RAY_STATUS_MAX_ATTEMPTS}..."

  if run_on_node "$HEAD_NODE" "$RAY_CMD status --address='$RAY_ADDRESS'"       | tee "$RUN_DIR/ray_status_attempt_${attempt}.txt"; then
    echo "Ray status succeeded on attempt ${attempt}."
    cp "$RUN_DIR/ray_status_attempt_${attempt}.txt" "$RUN_DIR/ray_status.txt"
    RAY_READY=1
    break
  fi

  echo "Ray status failed on attempt ${attempt}; waiting ${RAY_STATUS_SLEEP_SEC}s before retry..."
  sleep "$RAY_STATUS_SLEEP_SEC"
done

if [[ "$RAY_READY" -ne 1 ]]; then
  echo "ERROR: Ray cluster did not become ready after ${RAY_STATUS_MAX_ATTEMPTS} attempts."
  echo "Ray head log:"
  tail -n 160 "$RAY_LOG_DIR/ray_head_${HEAD_NODE}.log" || true

  for node in "${NODES[@]}"; do
    if [[ "$node" != "$HEAD_NODE" ]]; then
      echo "Ray worker log for $node:"
      tail -n 160 "$RAY_LOG_DIR/ray_worker_${node}.log" || true
    fi
  done

  exit 1
fi

echo "============================================================"
echo "Expected Ray resources"
echo "============================================================"
echo "For this run, Ray should show:"
echo "  Active nodes: ${NNODES}"
echo "  Total GPUs:   $(( NNODES * GPUS_PER_NODE ))"
echo "If Ray shows only 1 GPU for a 2-node run, vLLM will hang waiting"
echo "for a placement group."
echo "============================================================"

# ------------------------------------------------------------
# Launch vLLM server on Ray head node
# ------------------------------------------------------------
echo "============================================================"
echo "Launching multi-node NON-CONTAINERIZED vLLM server"
echo "Endpoint:      $SERVER_URL"
echo "vLLM log file: $VLLM_LOG_FILE"
echo "============================================================"

setsid bash -lc "
  export VLLM_HOST_IP='$HEAD_IP'

  '$VLLM_BIN' serve Qwen/Qwen2.5-7B-Instruct \
    --host 0.0.0.0 \
    --port '$PORT' \
    --tensor-parallel-size '$TP_SIZE' \
    --pipeline-parallel-size '$PP_SIZE' \
    --distributed-executor-backend ray \
    --dtype auto
" > "$VLLM_LOG_FILE" 2>&1 &

VLLM_PID=$!

echo "vLLM server PID: $VLLM_PID"
echo "vLLM log file:   $VLLM_LOG_FILE"

# ------------------------------------------------------------
# Wait for API readiness
# ------------------------------------------------------------
echo "============================================================"
echo "Waiting for vLLM API readiness"
echo "============================================================"

READY=0

for i in $(seq 1 900); do
  if curl -fsS "$SERVER_URL/v1/models" > "$MODELS_JSON" 2>/dev/null; then
    READY=1
    echo "vLLM server is ready after $i check(s)."
    break
  fi

  if ! kill -0 "$VLLM_PID" 2>/dev/null; then
    echo "ERROR: vLLM server exited before becoming ready."
    echo "Last 200 lines of vLLM log:"
    tail -n 200 "$VLLM_LOG_FILE" || true

    echo "Ray status:"
    run_on_node "$HEAD_NODE" "$RAY_CMD status --address='$RAY_ADDRESS'" || true

    exit 1
  fi

  if (( i % 30 == 0 )); then
    echo "Still waiting... check $i"
    echo "Last 40 lines of vLLM log:"
    tail -n 40 "$VLLM_LOG_FILE" || true
  fi

  sleep 2
done

if [[ "$READY" -ne 1 ]]; then
  echo "ERROR: vLLM server did not become ready in time."
  echo "Last 200 lines of vLLM log:"
  tail -n 200 "$VLLM_LOG_FILE" || true

  echo "Ray status:"
  run_on_node "$HEAD_NODE" "$RAY_CMD status --address='$RAY_ADDRESS'" || true

  exit 1
fi

echo "Model list saved to:"
echo "$MODELS_JSON"

# ------------------------------------------------------------
# Send one prompt to the hosted model
# ------------------------------------------------------------
cat > "$REQUEST_JSON" <<'EOF'
{
  "model": "Qwen/Qwen2.5-7B-Instruct",
  "messages": [
    {
      "role": "user",
      "content": "Tell me how LLM works in simple terms."
    }
  ],
  "max_tokens": 256,
  "temperature": 0
}
EOF

echo "============================================================"
echo "Sending smoke-test prompt"
echo "Request JSON:  $REQUEST_JSON"
echo "Response JSON: $RESPONSE_JSON"
echo "============================================================"

curl -fsS "$SERVER_URL/v1/chat/completions" \
  -H "Content-Type: application/json" \
  -d @"$REQUEST_JSON" \
  | tee "$RESPONSE_JSON"

echo
echo "============================================================"
echo "Extracting assistant response text"
echo "============================================================"

if command -v python3 >/dev/null 2>&1; then
  python3 - "$RESPONSE_JSON" "$RESPONSE_TXT" <<'PY'
import json
import sys

response_path = sys.argv[1]
text_path = sys.argv[2]

with open(response_path, "r", encoding="utf-8") as f:
    data = json.load(f)

text = data["choices"][0]["message"]["content"]

print(text)

with open(text_path, "w", encoding="utf-8") as f:
    f.write(text)
    f.write("\n")
PY

  echo
  echo "Assistant response text saved to:"
  echo "$RESPONSE_TXT"
else
  echo "python3 not found on host; raw JSON response is saved instead:"
  echo "$RESPONSE_JSON"
fi

echo "============================================================"
echo "Smoke test completed successfully"
echo "RUN_DIR:       $RUN_DIR"
echo "Ray status:    $RUN_DIR/ray_status.txt"
echo "Ray logs:      $RAY_LOG_DIR"
echo "vLLM log:      $VLLM_LOG_FILE"
echo "Response JSON: $RESPONSE_JSON"
echo "Date:          $(date)"
echo "============================================================"


# ------------------------------------------------------------
# Run GuideLLM benchmark in an isolated subshell
# ------------------------------------------------------------
echo "============================================================"
echo "Running GuideLLM benchmark"
echo "RUN_DIR: $RUN_DIR"
echo "============================================================"

export RATE=3
export DURATION=300
export GUIDELLM_LOG="$RUN_DIR/guidellm_rate${RATE}_${DURATION}s.log"

(
  set -euo pipefail

  echo "============================================================"
  echo "Activating GuideLLM environment in subshell"
  echo "============================================================"

  if [[ ! -f "$HOME/guidellm_vLLMBench/start_guidellm_env.sh" ]]; then
    echo "ERROR: GuideLLM startup script not found:"
    echo "$HOME/guidellm_vLLMBench/start_guidellm_env.sh"
    exit 1
  fi

  # Safe here: any module purge/load affects only this subshell.
  source "$HOME/guidellm_vLLMBench/start_guidellm_env.sh"

  echo "GuideLLM executable:"
  which guidellm

  echo "GuideLLM version:"
  guidellm --version || true

  echo "Checking endpoint from GuideLLM environment:"
  curl -fsS "$SERVER_URL/v1/models" >/dev/null

  cd "$RUN_DIR"

  # Some OpenAI-compatible clients expect an API key even if vLLM ignores it.
  export OPENAI_API_KEY="${OPENAI_API_KEY:-EMPTY}"

  guidellm benchmark \
    --target "$SERVER_URL" \
    --rate-type constant \
    --rate "$RATE" \
    --max-seconds "$DURATION" \
    --data "kind=synthetic_text,prompt_tokens=512,output_tokens=256" \
    2>&1 | tee "$GUIDELLM_LOG"
)

echo "============================================================"
echo "GuideLLM benchmark completed"
echo "Listing output files in RUN_DIR:"
echo "============================================================"
find "$RUN_DIR" -maxdepth 2 -type f -print | sort

echo "============================================================"
echo "Full workflow completed successfully"
echo "RUN_DIR:       $RUN_DIR"
echo "vLLM log:      $VLLM_LOG_FILE"
echo "GuideLLM log:  $GUIDELLM_LOG"
echo "Date:          $(date)"
echo "============================================================"
