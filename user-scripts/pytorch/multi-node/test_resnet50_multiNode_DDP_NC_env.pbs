#!/bin/bash
#PBS -N 4x8_NOCON_DDP_ENVSTYLE_NO_ETH
#PBS -P <project>
#PBS -q <queue>
#PBS -l place=scatter

# ------------------------------------------------------------
# Sweep examples
#
# 2x1:
# select=2:ncpus=12:ngpus=1:mpiprocs=1
#
# 2x2:
# select=2:ncpus=24:ngpus=2:mpiprocs=2
#
# 2x4:
# select=2:ncpus=48:ngpus=4:mpiprocs=4
#
# 2x8:
# select=2:ncpus=96:ngpus=8:mpiprocs=8
# ------------------------------------------------------------

#PBS -l select=2:ncpus=96:ngpus=8:mpiprocs=8

#PBS -l walltime=02:00:00
#PBS -j oe

cd "$PBS_O_WORKDIR" || exit 1

module load python/3.12.13
module load pytorch/2.11.0
module load nvhpc/26.3

SCRIPT="/path/to/resnet50_multiNode_DDP_NC_env.py"

# ------------------------------------------------------------
# Automatically derived from PBS allocation
# ------------------------------------------------------------

NPROCS=$(wc -l < "$PBS_NODEFILE")
NNODES=$(sort -u "$PBS_NODEFILE" | wc -l)
GPUS_PER_NODE=$((NPROCS / NNODES))

MASTER_ADDR=$(head -1 "$PBS_NODEFILE")

# Derive a per-job port from PBS_JOBID to avoid always using 29500.
JOB_NUM=$(echo "$PBS_JOBID" | sed 's/[^0-9].*//')
MASTER_PORT=$((20000 + JOB_NUM % 40000))

# ------------------------------------------------------------
# Use HPC-X OpenMPI from NVHPC
# ------------------------------------------------------------

NVROOT=$(dirname "$(dirname "$(dirname "$(command -v nvfortran)")")")

export PATH="${NVROOT}/comm_libs/hpcx/bin:${PATH}"
export LD_LIBRARY_PATH="${NVROOT}/comm_libs/hpcx/lib:${LD_LIBRARY_PATH:-}"

# ------------------------------------------------------------
# NCCL / DDP settings
# ------------------------------------------------------------

export MASTER_ADDR
export MASTER_PORT

export NCCL_IB_DISABLE=0
export TORCH_NCCL_ASYNC_ERROR_HANDLING=1
export OMP_NUM_THREADS=1

# Enable diagnostics for debugging
export NCCL_DEBUG=INFO
export NCCL_DEBUG_SUBSYS=INIT,NET,GRAPH

# IMPORTANT: EXCLUDE THE BOND_0 IN THE IB SELECTION TO PREVENT FAILURE
# export NCCL_IB_HCA=^mlx5_bond_0i
# OR: WE CAN EXCPLICITLY DEFINE THE AVAILABLE IB INTERFACES
export NCCL_IB_HCA=mlx5_0,mlx5_1,mlx5_2,mlx5_3,mlx5_4,mlx5_5,mlx5_8,mlx5_9


echo "========================================================="
echo "JOBID   : $PBS_JOBID"
echo "WORKDIR : $PBS_O_WORKDIR"
echo "DATE    : $(date)"
echo "LAYOUT  : ${NNODES} nodes × ${GPUS_PER_NODE} GPUs"
echo "WORLD   : ${NPROCS} total ranks"
echo "NODES   : $(sort -u "$PBS_NODEFILE" | paste -sd' ')"
echo "MASTER  : ${MASTER_ADDR}:${MASTER_PORT}"
echo "SCRIPT  : ${SCRIPT}"
echo "NCCL_IB_DISABLE      : ${NCCL_IB_DISABLE}"
echo "NCCL_DEBUG_SUBSYS    : ${NCCL_DEBUG_SUBSYS}"
echo "========================================================="

mpirun -np "$NPROCS" \
    -machinefile "$PBS_NODEFILE" \
    --mca plm_rsh_agent pbs_tmrsh \
    --map-by ppr:${GPUS_PER_NODE}:node \
    --bind-to none \
    -x PATH \
    -x LD_LIBRARY_PATH \
    -x MASTER_ADDR="$MASTER_ADDR" \
    -x MASTER_PORT="$MASTER_PORT" \
    -x NCCL_IB_DISABLE \
    -x NCCL_DEBUG \
    -x NCCL_DEBUG_SUBSYS \
    -x TORCH_NCCL_ASYNC_ERROR_HANDLING \
    -x OMP_NUM_THREADS \
    -x NCCL_IB_HCA \
    python3 "$SCRIPT"

EXIT_CODE=$?

echo "========================================================="
if [ $EXIT_CODE -eq 0 ]; then
    echo "==== RESNET50 DDP ENVSTYLE NO-ETH TEST PASSED ===="
else
    echo "==== RESNET50 DDP ENVSTYLE NO-ETH TEST FAILED (exit $EXIT_CODE) ===="
fi

exit $EXIT_CODE
